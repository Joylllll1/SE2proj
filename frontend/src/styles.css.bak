:root {
  color-scheme: light;
  --bg: #f5f5f7;
  --bg-panel: #f9fafb;
  --surface: #ffffff;
  --surface-soft: #f4f6f8;
  --surface-tint: #eef5ff;
  --text: #1d1d1f;
  --text-2: #555;
  --text-3: #8e8e93;
  --line: #e5e7eb;
  --line-soft: #eceef2;
  --blue: #0071e3;
  --blue-2: #005bab;
  --blue-soft: #e8f2ff;
  --green: #1aae39;
  --teal: #0f8d88;
  --orange: #dd5b00;
  --red: #c43d3d;
  --purple: #653d91;
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 12px 32px rgba(0, 0, 0, 0.1);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --sidebar: 240px;
  font-family: "SF Pro Display", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  color: var(--text);
  background:
    radial-gradient(circle at 12% 0%, rgba(207, 222, 246, 0.85), transparent 30%),
    radial-gradient(circle at 100% 14%, rgba(222, 230, 244, 0.8), transparent 26%),
    linear-gradient(180deg, #f3f6fb 0%, var(--bg) 42%, #e9eef6 100%);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

button,
input,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

button:focus-visible,
input:focus-visible,
textarea:focus-visible {
  outline: 3px solid rgba(0, 113, 227, 0.18);
  outline-offset: 2px;
}

img {
  display: block;
  max-width: 100%;
}

.app-icon {
  width: 20px;
  height: 20px;
  flex: 0 0 auto;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.app-icon.filled {
  stroke-width: 2.15;
}

.app-shell {
  display: flex;
  min-height: 100vh;
}

.sidebar {
  position: sticky;
  top: 0;
  display: flex;
  width: var(--sidebar);
  height: 100vh;
  flex-direction: column;
  flex-shrink: 0;
  border-right: 1px solid var(--line);
  background: #f5f5f7;
  z-index: 30;
}

.sidebar-top {
  padding: 20px 14px 0;
}

.sidebar-bottom {
  margin-top: auto;
  padding: 14px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  margin-bottom: 22px;
  padding: 6px 8px;
  border: 0;
  border-radius: 12px;
  background: transparent;
  color: inherit;
  text-align: left;
}

.brand:hover {
  background: var(--surface);
}

.brand-mark {
  display: grid;
  width: 36px;
  height: 36px;
  place-items: center;
  border-radius: 10px;
  color: #fff;
  background: linear-gradient(145deg, #134ba0 0%, var(--blue) 100%);
  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.2);
}

.brand strong,
.brand small {
  display: block;
}

.brand strong {
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.brand small {
  margin-top: 1px;
  color: var(--text-3);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.side-nav {
  display: grid;
  gap: 5px;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  min-height: 40px;
  padding: 0 12px;
  border: 1px solid transparent;
  border-radius: 8px;
  color: var(--text-2);
  background: transparent;
  font-size: 14px;
  font-weight: 600;
  text-align: left;
  transition: background 160ms ease, color 160ms ease;
}

.nav-item:hover {
  color: var(--text);
  background: rgba(0, 0, 0, 0.04);
}

.nav-item.active {
  color: var(--blue);
  background: var(--blue-soft);
  font-weight: 700;
}

.nav-item.active::before {
  position: absolute;
  left: -14px;
  width: 3px;
  height: 20px;
  border-radius: 0 999px 999px 0;
  background: var(--blue);
  content: "";
}

.nav-action {
  margin: 10px 0;
  color: #fff;
  background: var(--blue);
  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.2);
}

.nav-action:hover,
.nav-action.active {
  color: #fff;
  background: var(--blue-2);
}

.identity-card {
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--surface);
  box-shadow: var(--shadow-xs);
}

.identity-card {
  display: grid;
  grid-template-columns: 30px 1fr;
  gap: 10px;
}

.avatar {
  display: grid;
  width: 30px;
  height: 30px;
  place-items: center;
  border-radius: 8px;
  color: var(--blue);
  background: var(--blue-soft);
  font-size: 13px;
  font-weight: 700;
}

.identity-card strong {
  display: block;
  margin-top: 0;
  font-size: 12px;
}

.identity-card p {
  margin: 3px 0 0;
  color: var(--text-3);
  font-size: 11px;
  line-height: 1.5;
}

.workspace {
  min-width: 0;
  flex: 1;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  height: 60px;
  padding: 0 28px;
  border-bottom: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(12px);
}

.search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  width: min(480px, 100%);
  height: 38px;
  padding: 0 14px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #fff;
  color: var(--text-3);
  box-shadow: var(--shadow-xs);
}

.search-box input {
  width: 100%;
  border: 0;
  outline: 0;
  color: var(--text);
  background: transparent;
  font-size: 14px;
}

.search-box input::placeholder {
  color: #9aa6b7;
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.icon-button,
.profile-button {
  border: 1px solid var(--line);
  background: #fff;
  color: var(--text-2);
  box-shadow: var(--shadow-xs);
  transition: transform 160ms ease, border-color 160ms ease, color 160ms ease;
}

.icon-button {
  display: grid;
  width: 38px;
  height: 38px;
  place-items: center;
  border-radius: 999px;
}

.icon-button:hover,
.profile-button:hover {
  color: var(--blue);
  border-color: #b0c4de;
  transform: translateY(-1px);
}

.notification {
  position: relative;
}

.notification::after {
  position: absolute;
  top: 8px;
  right: 9px;
  width: 7px;
  height: 7px;
  border: 2px solid #fff;
  border-radius: 999px;
  background: var(--red);
  content: "";
}

.profile-button {
  display: flex;
  align-items: center;
  gap: 8px;
  height: 38px;
  padding: 4px 12px 4px 4px;
  border-radius: 999px;
}

.profile-button span {
  display: grid;
  width: 28px;
  height: 28px;
  place-items: center;
  border-radius: 999px;
  color: #fff;
  background: #1d1d1f;
  font-size: 12px;
  font-weight: 700;
}

.profile-button strong {
  font-size: 12px;
  font-weight: 600;
}

.page {
  padding: 24px 28px 48px;
}

.home-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: 20px;
  max-width: 1380px;
  margin: 0 auto;
}

.feed-column,
.right-rail,
.detail-layout,
.compose-page,
.collection-page,
.announcements-page,
.admin-page,
.trending-page,
.settings-page {
  min-width: 0;
}

.hero-card {
  position: relative;
  display: grid;
  min-height: 300px;
  grid-template-columns: 1fr 0.88fr;
  gap: 24px;
  overflow: hidden;
  padding: 28px;
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: var(--radius-lg);
  background:
    linear-gradient(135deg, rgba(0, 60, 80, 0.95), rgba(15, 60, 120, 0.92)),
    #0a2a3a;
  box-shadow: var(--shadow-md);
}

.hero-card::before {
  position: absolute;
  inset: -30% 30% 30% -20%;
  background: radial-gradient(circle, rgba(72, 151, 255, 0.28), transparent 58%);
  content: "";
}

.hero-copy {
  position: relative;
  z-index: 1;
  align-self: end;
  color: #fff;
}

.hero-copy h2 {
  max-width: 700px;
  margin: 14px 0 10px;
  font-size: clamp(30px, 4.5vw, 52px);
  line-height: 1.05;
  letter-spacing: -0.06em;
}

.hero-copy p {
  max-width: 560px;
  margin: 0;
  color: rgba(255, 255, 255, 0.72);
  font-size: 15px;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 24px;
}

.hero-visual {
  position: relative;
  z-index: 1;
  overflow: hidden;
  min-height: 240px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-md);
  background: #20344e;
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.2);
}

.hero-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.92) contrast(0.98);
}

.hero-dots {
  position: absolute;
  right: 34px;
  bottom: 24px;
  z-index: 2;
  display: flex;
  gap: 7px;
}

.hero-dots span {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.34);
}

.hero-dots .active {
  width: 28px;
  background: #fff;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18px;
  margin: 30px 0 18px;
}

.overview-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 18px;
}

.overview-card,
.collection-note,
.announcement-note,
.admin-note,
.detail-summary {
  border: 1px solid var(--line);
  background: rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-xs);
}

.overview-card {
  padding: 16px;
  border-radius: var(--radius-md);
}

.overview-label {
  display: inline-block;
  margin-bottom: 6px;
  color: var(--blue);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.overview-card strong {
  display: block;
  font-size: 17px;
  letter-spacing: -0.03em;
}

.overview-card p {
  margin: 6px 0 0;
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.65;
}

.section-head.large {
  align-items: center;
  margin-top: 0;
}

.eyebrow {
  margin: 0 0 6px;
  color: var(--blue);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  overflow-wrap: anywhere;
}

.section-head h1,
.compose-heading h1,
.collection-hero h1,
.section-head.large h1 {
  margin: 0;
  font-size: clamp(30px, 4.2vw, 44px);
  line-height: 1.1;
  letter-spacing: -0.05em;
}

.section-head h2 {
  margin: 0;
  font-size: 22px;
  letter-spacing: -0.03em;
}

.section-head p:not(.eyebrow),
.compose-heading p,
.collection-hero p,
.section-head.large p {
  margin: 9px 0 0;
  color: var(--text-2);
  line-height: 1.65;
}

.tabs,
.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tabs button,
.category-row button {
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #fff;
  color: var(--text-2);
  font-weight: 600;
  box-shadow: var(--shadow-xs);
  transition: background 160ms ease, color 160ms ease;
}

.tabs button {
  padding: 8px 14px;
  font-size: 13px;
}

.category-row {
  margin: 22px 0;
}

.category-row button {
  padding: 10px 16px;
  font-size: 14px;
}

.tabs button:hover,
.category-row button:hover {
  border-color: #b0c4de;
  color: var(--blue);
}

.tabs .active,
.category-row .active {
  color: #fff;
  border-color: #1d1d1f;
  background: #1d1d1f;
}

.result-hint {
  margin: 0 0 14px;
  color: var(--text-2);
  font-size: 14px;
}

.post-list {
  display: grid;
  gap: 16px;
}

.post-card,
.topic-card,
.detail-card,
.comment-input,
.comment-body,
.editor-card,
.ai-suggestion,
.announcement-card,
.new-event-card,
.report-queue,
.mapping-card,
.stat-card,
.owner-tools {
  border: 1px solid var(--line-soft);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
}

.post-card {
  overflow: hidden;
  border-radius: var(--radius-md);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.post-card:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.post-main {
  display: block;
  width: 100%;
  padding: 18px 20px 14px;
  border: 0;
  background: transparent;
  color: inherit;
  text-align: left;
}

.post-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 16px;
}

.user-block {
  display: flex;
  align-items: center;
  gap: 11px;
}

.anon-avatar {
  display: grid;
  width: 38px;
  height: 38px;
  flex: 0 0 auto;
  place-items: center;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--surface-soft);
  color: var(--text-3);
}

.anon-avatar.small {
  width: 34px;
  height: 34px;
  border-radius: 8px;
}

.user-block strong,
.user-block span {
  display: block;
}

.user-block strong {
  font-size: 14px;
}

.user-block span {
  margin-top: 2px;
  color: var(--text-3);
  font-size: 12px;
}

.mood,
.pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  width: fit-content;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  line-height: 1;
}

.mood {
  padding: 8px 10px;
  border: 1px solid transparent;
}

.pill {
  padding: 8px 12px;
}

.pill.blue {
  color: #fff;
  background: var(--blue);
}

.pill.green {
  color: #fff;
  background: var(--green);
}

.mood-calm {
  color: var(--teal);
  border-color: rgba(15, 141, 136, 0.16);
  background: rgba(15, 141, 136, 0.08);
}

.mood-happy {
  color: var(--green);
  border-color: rgba(22, 138, 72, 0.16);
  background: rgba(22, 138, 72, 0.08);
}

.mood-anxious {
  color: var(--orange);
  border-color: rgba(200, 91, 22, 0.16);
  background: rgba(200, 91, 22, 0.08);
}

.mood-sad {
  color: var(--purple);
  border-color: rgba(101, 61, 145, 0.16);
  background: rgba(101, 61, 145, 0.08);
}

.post-card h3 {
  margin: 0 0 8px;
  font-size: 20px;
  line-height: 1.35;
  letter-spacing: -0.03em;
}

.post-card p {
  margin: 0;
  color: #344054;
  font-size: 15px;
  line-height: 1.75;
}

.post-image {
  width: 100%;
  max-height: 320px;
  margin-top: 14px;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 10px 20px 14px;
  border-top: 1px solid var(--line-soft);
  background: #fafbfc;
}

.tag-row,
.metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  color: var(--text-3);
  font-size: 12px;
  font-weight: 600;
}

.tag-row span {
  color: var(--blue);
}

.metrics span {
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.metrics .app-icon {
  width: 16px;
  height: 16px;
}

.right-rail {
  position: sticky;
  top: 80px;
  display: grid;
  align-self: start;
  gap: 16px;
}

.topic-card,
.luck-card {
  border-radius: var(--radius-md);
  padding: 16px;
}

.luck-card {
  color: #fff;
  background: linear-gradient(145deg, #0f3d6e, #1a6dd4);
  box-shadow: var(--shadow-sm);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.panel-head div {
  display: flex;
  align-items: center;
  gap: 8px;
}

.panel-head span {
  color: inherit;
  font-size: 12px;
  opacity: 0.78;
}

.live-dot,
.status-ok::before {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #24c26a;
  box-shadow: 0 0 0 5px rgba(36, 194, 106, 0.12);
}

.ai-intro {
  margin: 15px 0;
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.65;
}

.chat-bubble {
  width: fit-content;
  max-width: 94%;
  margin: 8px 0;
  padding: 10px 12px;
  border-radius: 12px;
  font-size: 13px;
  line-height: 1.55;
}

.chat-bubble.ai {
  background: var(--surface-soft);
  border-top-left-radius: 5px;
}

.chat-bubble.me {
  margin-left: auto;
  color: #fff;
  background: var(--blue);
  border-top-right-radius: 5px;
}


.owner-tools button {
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #fff;
  color: var(--text-2);
  font-size: 12px;
  font-weight: 600;
}

.quick-actions button {
  padding: 9px 8px;
}

.luck-word {
  display: block;
  margin: 18px 0 8px;
  font-size: 38px;
  letter-spacing: 0.16em;
  text-align: center;
}

.luck-card p {
  margin: 0;
  color: rgba(255, 255, 255, 0.78);
  font-size: 13px;
  line-height: 1.7;
  text-align: center;
}

.topic-row {
  position: relative;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 6px;
  margin-top: 16px;
  padding-bottom: 12px;
  color: inherit;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none;
}

.topic-row small {
  color: var(--text-3);
  font-size: 11px;
}

.topic-row::after,
.topic-row i {
  position: absolute;
  bottom: 0;
  left: 0;
  height: 4px;
  border-radius: 999px;
  content: "";
}

.topic-row::after {
  width: 100%;
  background: #ecf1f7;
}

.topic-row i {
  background: var(--blue);
}

.primary-button,
.secondary-button,
.ghost-button,
.announcement-card button,
.new-event-card button,
.mapping-card button,
.report-item button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  border-radius: 999px;
  font-weight: 700;
  transition: transform 160ms ease, background 160ms ease, border-color 160ms ease, color 160ms ease;
}

.primary-button {
  border: 0;
  padding: 10px 18px;
  color: #fff;
  background: var(--blue);
  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.2);
}

.primary-button:hover {
  transform: translateY(-1px);
  background: var(--blue-2);
}

.secondary-button,
.ghost-button {
  padding: 10px 16px;
  border: 1px solid var(--line);
  background: #fff;
  color: var(--text-2);
}

.ghost-button {
  border-color: rgba(255, 255, 255, 0.28);
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
}

.detail-layout,
.compose-page,
.collection-page,
.announcements-page,
.admin-page {
  max-width: 1180px;
  margin: 0 auto;
}

.detail-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 16px;
}

.detail-heading h1 {
  margin: 0;
  font-size: clamp(30px, 4vw, 40px);
  letter-spacing: -0.055em;
}

.detail-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 10px 12px;
  border-radius: var(--radius-sm);
}

.detail-summary span {
  color: var(--text-2);
  font-size: 12px;
  font-weight: 700;
}

.breadcrumb {
  margin-bottom: 14px;
  color: var(--text-3);
  font-size: 13px;
  font-weight: 600;
}

.detail-card {
  padding: 18px;
  border-radius: var(--radius-lg);
}

.detail-card .post-card {
  border-color: var(--line-soft);
  box-shadow: none;
}

.owner-tools {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  padding: 12px;
  border-radius: var(--radius-md);
  background: var(--surface-tint);
}

.owner-tools div {
  display: grid;
  flex: 1;
  gap: 3px;
}

.owner-tools span {
  color: var(--text-2);
  font-size: 13px;
}

.owner-tools button {
  padding: 9px 12px;
}

.comments-section {
  margin-top: 28px;
}

.comment-input {
  padding: 14px;
  border-radius: var(--radius-md);
}

.comment-input textarea,
.editor-card textarea,
.editor-card input,
.lookup-row input {
  width: 100%;
  border: 0;
  outline: 0;
  color: var(--text);
  background: transparent;
}

.comment-input textarea {
  min-height: 86px;
  resize: vertical;
}

.comment-input div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding-top: 10px;
  border-top: 1px solid var(--line-soft);
}

.comment-input span {
  display: flex;
  gap: 12px;
  color: var(--text-3);
}

.comment-list {
  display: grid;
  gap: 14px;
  margin-top: 16px;
}

.comment {
  display: flex;
  gap: 12px;
}

.comment-body {
  flex: 1;
  padding: 14px;
  border-radius: var(--radius-md);
}

.comment.official .comment-body {
  border-color: #b0c4de;
  background: #f7fbff;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.comment-meta span {
  padding: 3px 7px;
  border-radius: 999px;
  color: var(--blue);
  background: var(--blue-soft);
  font-size: 10px;
  font-weight: 700;
}

.comment-body p {
  margin: 9px 0;
  color: #344054;
  line-height: 1.7;
}

.comment-actions {
  display: flex;
  gap: 14px;
  color: var(--text-3);
  font-size: 12px;
}

.comment-actions button {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font-weight: 700;
}

.comment-actions .app-icon {
  width: 15px;
  height: 15px;
}

.reply-list {
  display: grid;
  gap: 12px;
  margin-top: 14px;
  padding-left: 14px;
  border-left: 2px solid var(--line);
}

.reply p {
  margin: 5px 0;
  font-size: 14px;
}

.reply span {
  color: var(--text-3);
  font-size: 12px;
}

.compose-heading {
  max-width: 760px;
  margin-bottom: 24px;
}

.editor-card {
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.editor-card > input {
  padding: 18px 20px;
  border-bottom: 1px solid var(--line-soft);
  font-size: 20px;
  font-weight: 700;
}

.editor-card > textarea {
  min-height: 240px;
  padding: 20px;
  resize: vertical;
  font-size: 16px;
  line-height: 1.75;
}

.editor-tools,
.publish-row,
.emotion-picker {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  padding: 14px 20px;
  border-top: 1px solid var(--line-soft);
  background: #fafbfc;
}

.editor-tools button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  border: 1px dashed #ccc;
  border-radius: var(--radius-sm);
  background: #fff;
  color: var(--text-2);
  font-weight: 600;
}

.editor-tools span {
  margin-left: auto;
  color: var(--text-3);
  font-size: 13px;
  font-weight: 700;
}

.emotion-picker button {
  border: 1px solid transparent;
}

.publish-row {
  justify-content: space-between;
}

.publish-row label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--text-2);
  font-weight: 700;
}

.publish-row div {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.guidance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  margin-top: 22px;
}

.dark-callout,
.blue-callout,
.quote-card,
.server-card {
  overflow: hidden;
  padding: 20px;
  border-radius: var(--radius-md);
  color: #fff;
  box-shadow: var(--shadow-sm);
}

.dark-callout,
.quote-card,
.server-card {
  background: #1e3a5f;
}

.blue-callout {
  background: linear-gradient(145deg, #0e4a8a, var(--blue));
}

.dark-callout h3,
.blue-callout h3 {
  margin: 0 0 8px;
  font-size: 22px;
  letter-spacing: -0.035em;
}

.dark-callout p,
.blue-callout p,
.quote-card p {
  margin: 0;
  color: rgba(255, 255, 255, 0.76);
  line-height: 1.75;
}

.collection-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.collection-note,
.announcement-note,
.admin-note {
  display: grid;
  gap: 6px;
  margin: -2px 0 20px;
  padding: 14px 16px;
  border-radius: var(--radius-md);
}

.collection-note strong,
.announcement-note strong,
.admin-note strong {
  font-size: 14px;
  letter-spacing: -0.02em;
}

.collection-note p,
.announcement-note p,
.admin-note p {
  margin: 0;
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.7;
}

.ai-suggestion {
  display: flex;
  align-items: center;
  gap: 12px;
  max-width: 460px;
  padding: 12px;
  border-radius: var(--radius-md);
  background: var(--surface-tint);
}

.ai-suggestion span {
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.55;
}

.ai-suggestion button {
  border: 0;
  border-radius: 12px;
  padding: 8px 12px;
  color: var(--blue);
  background: #fff;
  font-weight: 700;
}

.masonry-grid {
  column-count: 2;
  column-gap: 18px;
}

.masonry-grid > * {
  display: inline-block;
  width: 100%;
  margin-bottom: 18px;
}

.post-card.compact .post-main {
  padding: 18px;
}

.post-card.compact h3 {
  font-size: 19px;
}

.quote-card {
  min-height: 280px;
}

.quote-card .app-icon {
  width: 30px;
  height: 30px;
  color: #c5d9ff;
}

.quote-card p {
  margin: 22px 0;
  font-size: 21px;
  font-style: italic;
}

.quote-card span {
  color: rgba(255, 255, 255, 0.54);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
}

.announcement-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20px;
}

.announcement-card {
  overflow: hidden;
  border-radius: var(--radius-md);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.announcement-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}

.announcement-card img {
  width: 100%;
  height: 206px;
  object-fit: cover;
}

.announcement-card > div {
  padding: 20px;
}

.announcement-card h3,
.new-event-card h3 {
  margin: 14px 0 14px;
  font-size: 22px;
  line-height: 1.35;
  letter-spacing: -0.035em;
}

.announcement-card p {
  display: flex;
  align-items: center;
  gap: 7px;
  margin: 8px 0;
  color: var(--text-2);
  font-size: 14px;
}

.announcement-card p .app-icon {
  width: 17px;
  height: 17px;
}

.announcement-card footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid var(--line-soft);
}

.announcement-card button,
.new-event-card button {
  border: 0;
  padding: 9px 13px;
  color: var(--blue);
  background: var(--blue-soft);
}

.new-event-card {
  display: grid;
  min-height: 360px;
  place-items: center;
  align-content: center;
  padding: 28px;
  border-style: dashed;
  color: var(--text-2);
  text-align: center;
}

.new-event-card > .app-icon {
  width: 60px;
  height: 60px;
  padding: 16px;
  border-radius: 50%;
  background: var(--blue-soft);
  color: var(--blue);
}

.new-event-card p {
  margin: 0 0 16px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 22px;
}

.stat-card {
  padding: 16px;
  border-radius: var(--radius-md);
}

.stat-card div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-3);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.stat-card strong {
  display: block;
  margin: 12px 0 4px;
  font-size: 30px;
  letter-spacing: -0.04em;
}

.stat-card small {
  color: var(--text-2);
}

.tone-success .app-icon,
.tone-success small {
  color: var(--green);
}

.tone-blue .app-icon {
  color: var(--blue);
}

.tone-warning .app-icon,
.tone-warning strong {
  color: var(--orange);
}

.tone-purple .app-icon {
  color: var(--purple);
}

.admin-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 20px;
}

.report-queue,
.mapping-card {
  border-radius: var(--radius-md);
  padding: 16px;
}

.report-queue .panel-head button {
  margin-left: 8px;
  padding: 8px 10px;
}

.report-item {
  margin-top: 14px;
  padding: 14px;
  border: 1px solid var(--line-soft);
  border-radius: var(--radius-md);
  background: #fafbfc;
}

.report-item.risk-high {
  border-left: 4px solid var(--red);
}

.report-item.risk-medium {
  border-left: 4px solid var(--orange);
}

.report-item.risk-low {
  border-left: 4px solid var(--blue);
}

.report-item header {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.report-item header div {
  display: flex;
  align-items: center;
  gap: 8px;
}

.report-item header span {
  padding: 4px 8px;
  border-radius: 999px;
  color: var(--orange);
  background: rgba(200, 91, 22, 0.09);
  font-size: 11px;
  font-weight: 700;
}

.report-item small {
  color: var(--text-3);
}

.report-item p {
  margin: 0;
  padding: 10px;
  border-radius: var(--radius-sm);
  background: #fff;
  color: #344054;
  line-height: 1.65;
}

.report-item footer {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 12px;
}

.report-item button {
  border: 1px solid var(--line);
  padding: 8px 12px;
  color: var(--text-2);
  background: #fff;
}

.report-item .danger {
  border: 0;
  color: #fff;
  background: var(--red);
}

.audit-panel {
  display: grid;
  align-content: start;
  gap: 18px;
}

.mapping-card p {
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.7;
}

.lookup-row {
  display: flex;
  gap: 8px;
  margin: 16px 0;
}

.lookup-row input {
  min-width: 0;
  padding: 10px 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #fff;
}

.lookup-row button {
  border: 0;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  color: #fff;
  background: var(--blue);
}

.mapping-card dl {
  display: grid;
  grid-template-columns: 90px minmax(0, 1fr);
  gap: 10px;
  margin: 0;
  padding-top: 14px;
  border-top: 1px solid var(--line-soft);
  color: var(--text-2);
  font-size: 13px;
}

.mapping-card dd {
  margin: 0;
  color: var(--text);
  font-weight: 700;
  text-align: right;
}

.server-card {
  display: grid;
  gap: 16px;
}

.status-ok {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  color: #9df2bd;
  font-size: 11px;
  font-weight: 700;
}

.status-ok::before {
  display: inline-block;
  content: "";
}

.progress-row span {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  color: rgba(255, 255, 255, 0.64);
}

.progress-row i {
  display: block;
  overflow: hidden;
  height: 7px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
}

.progress-row b {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #72a7ff, #9df2bd);
}

.empty-state {
  display: grid;
  place-items: center;
  padding: 48px 24px;
  border: 1px dashed #d0d5dd;
  border-radius: var(--radius-md);
  background: #fff;
  color: var(--text-2);
  text-align: center;
}

.empty-state .app-icon {
  width: 44px;
  height: 44px;
  color: var(--text-3);
}

.empty-state h3 {
  margin: 12px 0 6px;
}

.empty-state p {
  margin: 0;
}

.sidebar-compose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  height: 42px;
  margin-top: 12px;
  border: 0;
  border-radius: 999px;
  color: #fff;
  background: var(--blue);
  font-size: 14px;
  font-weight: 700;
  box-shadow: 0 4px 12px rgba(0, 113, 227, 0.2);
  transition: background 160ms ease, transform 160ms ease;
}

.sidebar-compose-btn:hover {
  background: var(--blue-2);
  transform: translateY(-1px);
}

.sidebar-compose-btn .app-icon {
  width: 18px;
  height: 18px;
}

.fab-compose {
  display: none;
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 40;
  width: 52px;
  height: 52px;
  place-items: center;
  border: 0;
  border-radius: 16px;
  color: #fff;
  background: var(--blue);
  box-shadow: 0 6px 20px rgba(0, 113, 227, 0.3);
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.fab-compose:hover {
  transform: scale(1.06);
  box-shadow: 0 8px 28px rgba(0, 113, 227, 0.4);
}

.fab-compose .app-icon {
  width: 22px;
  height: 22px;
}

/* AI Topbar Button (global, prominent) */
.ai-topbar-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  height: 38px;
  padding: 0 16px;
  border: 0;
  border-radius: 999px;
  color: #fff;
  background: linear-gradient(135deg, var(--blue), #6c5ce7);
  font-size: 13px;
  font-weight: 700;
  box-shadow: 0 2px 10px rgba(108, 92, 231, 0.3);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.ai-topbar-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(108, 92, 231, 0.4);
}

.ai-topbar-btn .app-icon {
  width: 18px;
  height: 18px;
  stroke: #fff;
}

/* AI Slide Panel (expanded from right) */
.ai-slide-panel {
  position: fixed;
  inset: 0;
  z-index: 100;
  pointer-events: none;
}

.ai-slide-panel.open {
  pointer-events: auto;
}

.ai-slide-overlay {
  position: absolute;
  inset: 0;
  opacity: 0;
  background: rgba(0, 0, 0, 0.3);
  transition: opacity 250ms ease;
}

.ai-slide-panel.open .ai-slide-overlay {
  opacity: 1;
}

.ai-slide-content {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 380px;
  display: flex;
  flex-direction: column;
  padding: 24px;
  border-left: 1px solid var(--line);
  background: #fff;
  box-shadow: -8px 0 32px rgba(0, 0, 0, 0.1);
  transform: translateX(100%);
  transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  overflow-y: auto;
}

.ai-slide-panel.open .ai-slide-content {
  transform: translateX(0);
}

.ai-slide-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.ai-slide-head > div {
  display: flex;
  align-items: center;
  gap: 8px;
}

.ai-slide-head strong {
  font-size: 16px;
  letter-spacing: -0.02em;
}

.ai-slide-close {
  display: grid;
  width: 32px;
  height: 32px;
  place-items: center;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #fff;
  color: var(--text-3);
  transition: color 160ms ease, border-color 160ms ease;
}

.ai-slide-close:hover {
  color: var(--text);
  border-color: var(--text-3);
}

.ai-slide-close .app-icon {
  transform: rotate(45deg);
  width: 16px;
  height: 16px;
}

.ai-chat-input {
  display: flex;
  gap: 8px;
  margin-top: auto;
  padding-top: 16px;
  border-top: 1px solid var(--line-soft);
}

.ai-chat-input input {
  flex: 1;
  min-width: 0;
  height: 40px;
  padding: 0 14px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--surface-soft);
  color: var(--text);
  font-size: 14px;
}

.ai-chat-input input::placeholder {
  color: var(--text-3);
}

.ai-chat-input .primary-button {
  flex-shrink: 0;
  height: 40px;
  padding: 0 16px;
}

/* Trending Page */
.trending-page {
  max-width: 1180px;
  margin: 0 auto;
}

.trending-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.trending-card {
  padding: 20px;
  border: 1px solid var(--line-soft);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.trending-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.trending-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.trending-rank {
  display: grid;
  width: 32px;
  height: 32px;
  place-items: center;
  border-radius: 8px;
  background: var(--surface-soft);
  color: var(--text);
  font-size: 14px;
  font-weight: 700;
}

.trending-heat {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--orange);
  font-size: 13px;
  font-weight: 700;
}

.trending-heat .app-icon {
  width: 16px;
  height: 16px;
}

.trending-card h3 {
  margin: 0 0 8px;
  font-size: 20px;
  letter-spacing: -0.03em;
  color: var(--text);
}

.trending-card p {
  margin: 0;
  color: var(--text-2);
  font-size: 14px;
  line-height: 1.6;
}

.trending-card footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid var(--line-soft);
}

.trending-card footer span {
  color: var(--text-3);
  font-size: 13px;
  font-weight: 600;
}

.trending-card footer button {
  border: 0;
  padding: 8px 14px;
  border-radius: 999px;
  color: var(--blue);
  background: var(--blue-soft);
  font-size: 13px;
  font-weight: 700;
}

.trending-bar {
  overflow: hidden;
  height: 4px;
  margin-top: 14px;
  border-radius: 999px;
  background: var(--surface-soft);
}

.trending-bar i {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--blue), var(--orange));
}

/* Settings Page */
.settings-page {
  max-width: 960px;
  margin: 0 auto;
}

.settings-grid {
  display: grid;
  gap: 18px;
}

.settings-card {
  overflow: hidden;
  border: 1px solid var(--line-soft);
  border-radius: var(--radius-md);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
}

.settings-card-head {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--line-soft);
  background: #fafbfc;
}

.settings-card-head .app-icon {
  width: 22px;
  height: 22px;
  color: var(--blue);
}

.settings-card-head strong {
  display: block;
  font-size: 16px;
  letter-spacing: -0.02em;
}

.settings-card-head p {
  margin: 3px 0 0;
  color: var(--text-3);
  font-size: 13px;
}

.settings-rows {
  display: grid;
  gap: 0;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 20px;
  border-bottom: 1px solid var(--line-soft);
  font-size: 14px;
}

.settings-row:last-child {
  border-bottom: 0;
}

.settings-row > span {
  color: var(--text-2);
}

.settings-row > strong {
  font-size: 14px;
  font-weight: 600;
}

.settings-row .secondary-button {
  padding: 7px 14px;
  font-size: 13px;
}

.toggle-row {
  padding: 12px 20px;
}

.toggle {
  position: relative;
  display: inline-block;
  width: 44px;
  height: 26px;
  flex-shrink: 0;
}

.toggle input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: absolute;
  inset: 0;
  border-radius: 999px;
  background: #d1d5db;
  cursor: pointer;
  transition: background 200ms ease;
}

.toggle-slider::before {
  position: absolute;
  bottom: 3px;
  left: 3px;
  width: 20px;
  height: 20px;
  border-radius: 999px;
  background: #fff;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  content: "";
  transition: transform 200ms ease;
}

.toggle input:checked + .toggle-slider {
  background: var(--blue);
}

.toggle input:checked + .toggle-slider::before {
  transform: translateX(18px);
}

.mobile-nav {
  display: none;
}

@media (max-width: 1180px) {
  .home-grid,
  .admin-grid {
    grid-template-columns: 1fr;
  }

  .overview-strip {
    grid-template-columns: 1fr;
  }

  .right-rail {
    position: static;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .announcement-grid,
  .stats-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .trending-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .sidebar {
    display: none;
  }

  .fab-compose {
    display: grid;
  }

  .topbar {
    padding: 0 16px;
  }

  .profile-button strong {
    display: none;
  }

  .page {
    padding: 20px 16px 96px;
  }

  .hero-card {
    grid-template-columns: 1fr;
    padding: 22px;
  }

  .hero-visual {
    min-height: 210px;
  }

  .right-rail,
  .guidance-grid,
  .collection-hero {
    grid-template-columns: 1fr;
  }

  .right-rail {
    display: grid;
  }

  .collection-hero {
    display: grid;
  }

  .mobile-nav {
    position: fixed;
    right: 12px;
    bottom: 12px;
    left: 12px;
    z-index: 50;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
    padding: 8px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-md);
  }

  .mobile-nav button {
    display: grid;
    place-items: center;
    gap: 4px;
    min-width: 0;
    padding: 8px 4px;
    border: 0;
    border-radius: 16px;
    background: transparent;
    color: var(--text-3);
    font-size: 10px;
    font-weight: 700;
  }

  .mobile-nav button.active {
    color: var(--blue);
    background: var(--blue-soft);
  }
}

@media (max-width: 680px) {
  .topbar-actions .icon-button:first-child {
    display: none;
  }

  .section-head,
  .section-head.large,
  .post-footer,
  .owner-tools,
  .publish-row,
  .detail-heading {
    align-items: stretch;
    flex-direction: column;
  }

  .post-header {
    flex-direction: column;
  }

  .tabs {
    width: 100%;
  }

  .tabs button {
    flex: 1;
  }

  .masonry-grid {
    column-count: 1;
  }

  .announcement-grid,
  .stats-grid,
  .right-rail {
    grid-template-columns: 1fr;
  }

  .trending-grid {
    grid-template-columns: 1fr;
  }

  .comment {
    gap: 9px;
  }

  .comment-input div,
  .lookup-row {
    align-items: stretch;
    flex-direction: column;
  }

  .mapping-card dl {
    grid-template-columns: 1fr;
  }

  .mapping-card dd {
    text-align: left;
  }
}

/* Toast */
.toast {
  position: fixed;
  bottom: 100px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 200;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 20px;
  border-radius: 999px;
  background: #1d1d1f;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  box-shadow: var(--shadow-md);
  animation: toast-in 0.25s ease;
}

.toast .app-icon {
  width: 18px;
  height: 18px;
  stroke: #24c26a;
}

@keyframes toast-in {
  from { opacity: 0; transform: translateX(-50%) translateY(12px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* Chat Messages Scrollable */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 12px;
}

/* Metric Buttons (like/bookmark) */
.metric-btn {
  cursor: pointer;
  transition: color 160ms ease, transform 160ms ease;
}

.metric-btn:hover {
  transform: scale(1.08);
}

.metric-btn.active {
  color: var(--red);
}

.metric-btn.active:last-child {
  color: var(--blue);
}

/* Breadcrumb Link */
.breadcrumb-link {
  padding: 0;
  border: 0;
  background: transparent;
  color: var(--text-3);
  font-size: inherit;
  font-weight: 600;
  cursor: pointer;
  transition: color 160ms ease;
}

.breadcrumb-link:hover {
  color: var(--blue);
}

/* Editor Tags */
.editor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px 20px;
  border-top: 1px solid var(--line-soft);
  background: #fafbfc;
}

.editor-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 999px;
  background: var(--blue-soft);
  color: var(--blue);
  font-size: 13px;
  font-weight: 600;
}

.editor-tag button {
  display: grid;
  width: 16px;
  height: 16px;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 999px;
  background: transparent;
  color: var(--blue);
  font-size: 14px;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 160ms ease;
}

.editor-tag button:hover {
  opacity: 1;
}

/* Mood Selected */
.mood.selected {
  box-shadow: 0 0 0 2px var(--blue);
}

/* Comment ID */
.comment-id {
  color: var(--text-3);
  font-size: 11px;
  font-weight: 600;
}

/* Publish Hint */
.publish-hint {
  margin: 0;
  color: var(--text-3);
  font-size: 13px;
  font-weight: 500;
}

/* Modal */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 150;
  display: grid;
  place-items: center;
  background: rgba(0, 0, 0, 0.4);
  animation: modal-fade-in 200ms ease;
}

@keyframes modal-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  width: min(560px, 90vw);
  max-height: 85vh;
  overflow-y: auto;
  border-radius: var(--radius-lg);
  background: #fff;
  box-shadow: var(--shadow-md);
  animation: modal-scale-in 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes modal-scale-in {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-image {
  width: 100%;
  height: 240px;
  object-fit: cover;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.modal-body {
  padding: 24px;
}

.modal-body h2 {
  margin: 14px 0 10px;
  font-size: 24px;
  letter-spacing: -0.03em;
}

.modal-body p {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 8px 0;
  color: var(--text-2);
  font-size: 15px;
}

.modal-body .app-icon {
  width: 18px;
  height: 18px;
  color: var(--text-3);
}

.modal-desc {
  display: block !important;
  margin-top: 16px !important;
  padding-top: 16px;
  border-top: 1px solid var(--line-soft);
  line-height: 1.75;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 20px;
}

.modal-form {
  display: grid;
  gap: 12px;
  margin-top: 16px;
}

.modal-form input,
.modal-form textarea {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #fff;
  color: var(--text);
  font-size: 14px;
}

.modal-form textarea {
  min-height: 80px;
  resize: vertical;
}

.modal-form input:focus,
.modal-form textarea:focus {
  outline: none;
  border-color: var(--blue);
}

/* Editor Image Preview */
.editor-image-preview {
  position: relative;
  padding: 12px 20px;
  border-top: 1px solid var(--line-soft);
  background: #fafbfc;
}

.editor-image-preview img {
  width: 100%;
  max-height: 200px;
  object-fit: cover;
  border-radius: var(--radius-sm);
}

.editor-image-remove {
  position: absolute;
  top: 16px;
  right: 24px;
  width: 28px;
  height: 28px;
  display: grid;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18px;
  cursor: pointer;
}

/* Editor Tag Area */
.editor-tag-area {
  padding: 12px 20px;
  border-top: 1px solid var(--line-soft);
  background: #fafbfc;
}

.tag-input-inline {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 8px;
}

.tag-hash {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid var(--line);
  border-right: 0;
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  background: var(--blue-soft);
  color: var(--blue);
  font-size: 16px;
  font-weight: 700;
}

.tag-input-inline input {
  height: 36px;
  min-width: 0;
  flex: 1;
  padding: 0 10px;
  border: 1px solid var(--line);
  border-radius: 0;
  background: #fff;
  font-size: 14px;
}

.tag-input-inline input:focus {
  outline: none;
  border-color: var(--blue);
}

.tag-input-inline button {
  height: 36px;
  padding: 0 14px;
  border: 1px solid var(--line);
  border-left: 0;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  background: var(--blue);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
}

.tag-input-inline button:disabled {
  background: var(--surface-soft);
  color: var(--text-3);
  cursor: not-allowed;
}

.tag-suggestions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
}

.tag-suggestions-label {
  color: var(--text-3);
  font-size: 12px;
  font-weight: 600;
}

.tag-suggestion {
  padding: 5px 10px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #fff;
  color: var(--blue);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: background 160ms ease, border-color 160ms ease;
}

.tag-suggestion:hover {
  background: var(--blue-soft);
  border-color: #b0c4de;
}

/* Hero dots clickable */
.hero-dots span {
  cursor: pointer;
}

/* Hero carousel transitions */
.hero-copy,
.hero-visual img {
  transition: opacity 300ms ease, transform 300ms ease;
}

.hero-copy.transitioning {
  opacity: 0;
  transform: translateY(8px);
}

.hero-visual img.transitioning {
  opacity: 0;
  transform: scale(1.02);
}

/* Comment Toolbar */
.comment-toolbar {
  display: flex;
  gap: 8px;
}

.toolbar-btn {
  display: grid;
  width: 32px;
  height: 32px;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 6px;
  background: transparent;
  color: var(--text-3);
  cursor: pointer;
  transition: background 160ms ease, color 160ms ease;
}

.toolbar-btn:hover {
  background: var(--surface-soft);
  color: var(--blue);
}

.toolbar-btn .app-icon {
  width: 18px;
  height: 18px;
}

/* Emoji Picker */
.emoji-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #fff;
  box-shadow: var(--shadow-sm);
  margin-bottom: 10px;
}

.emoji-item {
  width: 32px;
  height: 32px;
  display: grid;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 6px;
  background: transparent;
  font-size: 18px;
  cursor: pointer;
  transition: background 160ms ease;
}

.emoji-item:hover {
  background: var(--surface-soft);
}

/* Mention Dropdown */
.mention-dropdown {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 6px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #fff;
  box-shadow: var(--shadow-sm);
  margin-bottom: 10px;
  max-height: 200px;
  overflow-y: auto;
}

.mention-item {
  padding: 8px 12px;
  border: 0;
  border-radius: 6px;
  background: transparent;
  color: var(--text);
  font-size: 14px;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  transition: background 160ms ease;
}

.mention-item:hover {
  background: var(--blue-soft);
  color: var(--blue);
}

/* Comment Image Preview */
.comment-image-preview {
  position: relative;
  margin-top: 10px;
}

.comment-image-preview img {
  max-width: 200px;
  max-height: 150px;
  border-radius: var(--radius-sm);
  object-fit: cover;
}

.comment-image-remove {
  position: absolute;
  top: 6px;
  left: 6px;
  width: 24px;
  height: 24px;
  display: grid;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 16px;
  cursor: pointer;
}

/* Notification Dropdown */
.notif-wrapper {
  position: relative;
}

.notif-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 340px;
  max-height: 400px;
  overflow-y: auto;
  border: 1px solid var(--line);
  border-radius: var(--radius-md);
  background: #fff;
  box-shadow: var(--shadow-md);
  z-index: 100;
  animation: notif-in 200ms ease;
}

@keyframes notif-in {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

.notif-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid var(--line-soft);
  background: #fafbfc;
}

.notif-header strong {
  font-size: 15px;
}

.notif-mark-read {
  padding: 4px 10px;
  border: 0;
  border-radius: 999px;
  background: var(--blue-soft);
  color: var(--blue);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
}

.notif-empty {
  padding: 32px 16px;
  text-align: center;
  color: var(--text-3);
}

.notif-item {
  display: flex;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--line-soft);
  transition: background 160ms ease;
}

.notif-item:last-child {
  border-bottom: 0;
}

.notif-item:hover {
  background: var(--surface-soft);
}

.notif-item.unread {
  background: rgba(0, 113, 227, 0.04);
}

.notif-dot {
  width: 8px;
  height: 8px;
  flex-shrink: 0;
  margin-top: 6px;
  border-radius: 999px;
  background: var(--blue);
  opacity: 0;
}

.notif-item.unread .notif-dot {
  opacity: 1;
}

.notif-item p {
  margin: 0;
  font-size: 14px;
  line-height: 1.5;
  color: var(--text);
}

.notif-item small {
  display: block;
  margin-top: 4px;
  color: var(--text-3);
  font-size: 12px;
}

/* Pending Event Item (Admin) */
.pending-event-item {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 12px;
  align-items: start;
  padding: 12px;
  margin-top: 12px;
  border: 1px solid var(--line-soft);
  border-radius: var(--radius-sm);
  background: #fafbfc;
}

.pending-event-poster {
  width: 80px;
  height: 60px;
  border-radius: 6px;
  object-fit: cover;
}

.pending-event-info {
  min-width: 0;
}

.pending-event-info strong {
  display: block;
  font-size: 14px;
  margin-bottom: 4px;
}

.pending-event-info span {
  display: block;
  color: var(--text-3);
  font-size: 12px;
}

.pending-event-info p {
  margin: 6px 0 0;
  color: var(--text-2);
  font-size: 13px;
  line-height: 1.5;
}

.pending-event-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.pending-event-actions button {
  padding: 6px 12px;
  font-size: 12px;
}

/* Poster Upload */
.poster-upload {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.poster-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-2);
}

.poster-hint {
  color: var(--green);
  font-size: 12px;
  font-weight: 600;
}
